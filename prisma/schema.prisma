generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DailyPrice {
  id        Int      @id @default(autoincrement())
  // 这里保存的是 ETF 代码，例如 SPY / QQQ。
  symbol    String
  // 交易日日期，代表该日线属于哪一个市场交易日。
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 同一个 ETF 在同一个交易日只允许存在一条记录。
  @@unique([symbol, date])
  @@index([symbol, date])
}

model MorningCloseSnapshot {
  id              Int      @id @default(autoincrement())
  symbol          String
  snapshotDate    DateTime
  price           Float
  previousClose   Float
  change          Float
  percentChange   Float
  sourceTimestamp DateTime
  sourceLabel     String
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([symbol, snapshotDate])
  @@index([snapshotDate, symbol])
}

model SyncCheckpoint {
  id          Int      @id @default(autoincrement())
  jobType     String
  bizDate     DateTime
  isSuccess   Boolean
  message     String?
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobType, bizDate])
  @@index([bizDate, jobType])
}

model ManualSnapshotState {
  id               Int      @id @default(autoincrement())
  groupKey         String   @unique
  payloadJson      String?
  lastSuccessAt    DateTime?
  lastAttemptAt    DateTime?
  lastErrorMessage String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FundQuarterlyTracking {
  id               Int      @id @default(autoincrement())
  fundCode         String
  // 先按页面类型区分场内 / 场外，后续如果开放给不同用户，可继续在这里扩展维度。
  fundKind         String
  isActive         Boolean  @default(true)
  latestPayloadJson String?
  lastFetchedAt    DateTime?
  latestReportDate DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([fundKind, fundCode])
  @@index([fundKind, isActive, updatedAt])
  @@index([fundKind, latestReportDate])
}
